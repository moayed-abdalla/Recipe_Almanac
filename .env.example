# Copy to .env.local and fill in from Supabase Dashboard → Settings → API Keys
# https://supabase.com/dashboard/project/_/settings/api-keys

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Publishable key (sb_publishable_...) — safe for browser via NEXT_PUBLIC_
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key_here
# Secret key (sb_secret_...) — server-only; never prefix with NEXT_PUBLIC_
SUPABASE_SECRET_KEY=your_secret_key_here

# Admin dashboard (/admin) — server-only; never commit real values
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password
# Long random string, e.g. openssl rand -hex 32
ADMIN_SESSION_SECRET=replace_with_long_random_secret
